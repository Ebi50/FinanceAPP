/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a mixed security model. User profiles are stored under
 * /users/{userId} and are private to the owning user. Expense categories and transactions
 * are stored in top-level collections and are globally accessible by all authenticated users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only to the user.
 * - /expenseCategories/{expenseCategoryId}: Stores expense categories, globally accessible.
 * - /transactions/{transactionId}: Stores transaction data, globally accessible.
 *
 * Key Security Decisions:
 * - User listing is denied to prevent enumeration.
 * - Expense categories and transactions are globally accessible to all authenticated users.
 * - Data validation is minimal, focusing on ownership and relational integrity.
 *
 * Denormalization for Authorization:
 *  - Ownership is enforced by matching the userId in the document data with the userId in the path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profiles. Only the user can read and write their own profile.
     * @path /users/{userId}
     * @allow (create, update, delete, get, list) if the user is the owner of the profile.
     *   Example: A user with UID "user123" can create, update, delete, get and list the document at /users/user123.
     * @deny (create, update, delete, get, list) if the user is not the owner of the profile.
     *   Example: A user with UID "user456" cannot create, update, delete, get or list the document at /users/user123.
     * @principle Enforces document ownership for writes and reads.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Allows any authenticated user to read or write expense categories.
     * @path /expenseCategories/{expenseCategoryId}
     * @allow (create, update, delete, get, list) if the user is authenticated.
     *   Example: Any logged-in user can create, update, delete, get or list any document in /expenseCategories.
     * @deny None
     * @principle Grants global read and write access to expense categories for authenticated users.
     */
    match /expenseCategories/{expenseCategoryId} {
        function isSignedIn() {
            return request.auth != null;
        }
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows any authenticated user to read or write transactions.
     * @path /transactions/{transactionId}
     * @allow (create, update, delete, get, list) if the user is authenticated.
     *   Example: Any logged-in user can create, update, delete, get or list any document in /transactions.
     * @deny None
     * @principle Grants global read and write access to transactions for authenticated users.
     */
    match /transactions/{transactionId} {
      function isSignedIn() {
          return request.auth != null;
      }
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}