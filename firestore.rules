/**
 * @fileoverview Firestore Security Rules for Expense Tracker App
 *
 * Core Philosophy:
 * This ruleset prioritizes security and data ownership. User profiles are private and only accessible to the owning user.
 * Expense categories and transactions are shared across all users, enabling a collaborative environment.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles. Each user can only access their own profile.
 * - /expenseCategories/{expenseCategoryId}: Stores expense categories. All authenticated users can read and write to this collection.
 * - /transactions/{transactionId}: Stores transaction data. All authenticated users can read and write to this collection.
 *
 * Key Security Decisions:
 * - Expense categories are globally accessible to all authenticated users.
 * - Transactions are globally accessible to all authenticated users.
 * - User profiles are strictly private; only the owning user can read or write their profile.
 *
 * Denormalization for Authorization: N/A (No denormalization is needed in this basic ruleset.)
 * Structural Segregation: User profiles are segregated into a private /users collection, while shared data resides in top-level collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile.
     *   Request: { auth: { uid: 'user123' }, resource: { data: { id: 'user123' } } }
     * @allow (get) User with ID 'user123' can read their profile.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (update) User with ID 'user123' can update their profile.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (delete) User with ID 'user123' can delete their profile.
     *   Request: { auth: { uid: 'user123' } }
     * @deny (create) User with ID 'user123' cannot create a profile for user 'user456'.
     *   Request: { auth: { uid: 'user123' }, resource: { data: { id: 'user456' } } }
     * @deny (get) User with ID 'user123' cannot read the profile of user 'user456'.
     *   Request: { auth: { uid: 'user123' } }
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages access to expense categories. All authenticated users can read and write.
     * @path /expenseCategories/{expenseCategoryId}
     * @allow (get) Any authenticated user can read an expense category.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (list) Any authenticated user can list expense categories.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (create) Any authenticated user can create an expense category.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (update) Any authenticated user can update an expense category.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (delete) Any authenticated user can delete an expense category.
     *   Request: { auth: { uid: 'user123' } }
     * @principle Expense categories are shared across all authenticated users.
     */
    match /expenseCategories/{expenseCategoryId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to transactions. All authenticated users can read and write.
     * @path /transactions/{transactionId}
     * @allow (get) Any authenticated user can read a transaction.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (list) Any authenticated user can list transactions.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (create) Any authenticated user can create a transaction.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (update) Any authenticated user can update a transaction.
     *   Request: { auth: { uid: 'user123' } }
     * @allow (delete) Any authenticated user can delete a transaction.
     *   Request: { auth: { uid: 'user123' } }
     * @principle Transactions are shared across all authenticated users.
     */
    match /transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }

  // Helper Functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
  }
}